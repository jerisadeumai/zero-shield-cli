# JeriSadeuM AI - Zero-Shield CLI Environment Template
# Copy this file to .env and fill in your actual values.

# GitHub Authentication (Required for Agentic Reasoning Engine)
GITHUB_TOKEN=your_personal_access_token_here

# Target Security Group for Quarantine Operations
# Provide the ID of the isolated SG you want compromised instances moved to.
QUARANTINE_SG_ID=sg-your_quarantine_group_id_here

# AWS Credentials (Required for local usage outside pre-authenticated environments such as AWS CloudShell)
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here
AWS_DEFAULT_REGION=us-east-1
